# Copy to .env and fill in. The Claude-call wrapper reads ANTHROPIC_API_KEY from the
# environment. (.env is gitignored — never commit your real key.)
ANTHROPIC_API_KEY=

# Model used for EVERY Claude call (wrapper default: claude-opus-4-8).
# For cheap testing, use Haiku 4.5:
# STUDYBUDDY_MODEL=claude-haiku-4-5-20251001

# The web_search tool (the opt-in `harvest-web` step) needs Opus 4.6+, so it overrides
# STUDYBUDDY_MODEL for that one call only. Default: claude-opus-4-6. Leave unset if you
# are not using web-search harvesting.
# STUDYBUDDY_WEBSEARCH_MODEL=claude-opus-4-6

# Offline test mode: canned, schema-valid outputs, no network, no key. Unset for live runs.
# STUDYBUDDY_OFFLINE=1
